---

<div
  id="preloader"
  class="fixed inset-0 z-[10000] bg-brand-black flex flex-col justify-start p-6 md:p-12"
  aria-hidden="true"
>
  <!-- Terminal output -->
  <div
    id="terminal-output"
    class="font-sans font-400 text-brand-red uppercase text-[11px] leading-snug tracking-wider whitespace-pre-wrap break-all"
  >
  </div>

  <!-- Prompt line: C:\> with blinking cursor -->
  <div
    id="terminal-prompt"
    class="font-sans font-400 text-brand-red uppercase text-[11px] leading-snug tracking-wider flex items-center gap-0 opacity-0"
  >
    <span>C:\&gt;&nbsp;</span><span
      id="terminal-cursor"
      class="cursor-blink inline-block w-[0.55em] h-[1.1em] bg-brand-red align-middle"
    ></span>
  </div>
</div>

<style>
  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }
  .cursor-blink {
    animation: blink 0.75s step-end infinite;
  }
  :global(.preloader-hidden) #preloader {
    display: none !important;
  }
</style>

<script>
  function startPreloader() {
    const preloader = document.getElementById("preloader");
    const output = document.getElementById("terminal-output");
    const promptEl = document.getElementById("terminal-prompt");

    if (!preloader || !output || !promptEl) return;

    const isFirstVisit = !sessionStorage.getItem("ha-preloader-shown");
    const isLanding =
      window.location.pathname === "/" ||
      window.location.pathname === "/index.html";

    if (!isFirstVisit || !isLanding) {
      preloader.style.display = "none";
      return;
    }

    // Lock scroll while preloader is visible
    document.body.style.overflow = "hidden";

    // ─── PHASE 1: C:\> prompt, 1.2s de tensión ───
    promptEl.style.opacity = "1";

    // ─── PHASE 2: Avalancha rápida de texto, ~1s ───
    const CHARS =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()<>?/\\|[]{}=+-_:;.,~`";
    const KEYWORDS = [
      "LOADING SYSTEM... ",
      "BOOT SEQUENCE INIT ",
      "HUMANOIDES & ASOCIADOS ",
      "KERNEL PANIC: NONE ",
      "OPERACIONES CREATIVAS ",
      "MODULE: DESIGN.DLL ",
      "PROCESS ID: 0XFA2A2A ",
      "EXEC: IMAGINATION.EXE ",
      "CHECKSUM: OK ",
      "BIOS VER: H&A-2025 ",
      "FATAL ERROR: BOREDOM ",
      "NET START CREATIVE ",
    ];

    let avalancheInterval: ReturnType<typeof setInterval> | null = null;

    const startAvalanche = () => {
      promptEl.style.opacity = "0";
      output.textContent = "";

      let tick = 0;
      const totalTicks = 50; // ~1s at 20ms per tick

      avalancheInterval = setInterval(() => {
        tick++;

        const lineLength = Math.floor(Math.random() * 55) + 25;
        let line =
          tick % 7 === 0
            ? KEYWORDS[Math.floor(Math.random() * KEYWORDS.length)].padEnd(
                lineLength,
                CHARS[Math.floor(Math.random() * CHARS.length)],
              )
            : Array.from(
                { length: lineLength },
                () => CHARS[Math.floor(Math.random() * CHARS.length)],
              ).join("");

        output.textContent += line + "\n";

        // Only keep last 8 lines visible — concise, not overwhelming
        const lines = output.textContent.split("\n");
        if (lines.length > 9) {
          output.textContent = lines.slice(-9).join("\n");
        }

        if (tick >= totalTicks) {
          if (avalancheInterval) clearInterval(avalancheInterval);
          finalize();
        }
      }, 20);
    };

    // ─── PHASE 3: Corte en seco — sin ease, sin fade ───
    const finalize = () => {
      preloader.style.display = "none";
      document.body.style.overflow = "";
      sessionStorage.setItem("ha-preloader-shown", "true");
    };

    setTimeout(startAvalanche, 1200);
  }

  document.addEventListener("astro:page-load", startPreloader);
</script>
